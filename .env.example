# Set these in Coolify UI for production. Never commit real values.

# App
NEXTAUTH_SECRET=change-me-long-random-string
NEXTAUTH_URL=https://printables.99dfy.com

# Database (Coolify sibling Postgres service)
DATABASE_URL=postgresql://user:pass@postgres:5432/printables

# OpenAI (content + listing generation)
OPENAI_API_KEY=sk-...

# Resend (magic link + transactional email)
RESEND_API_KEY=re_...
RESEND_FROM="Printables <noreply@99dfy.com>"

# Storage (local Coolify volume)
STORAGE_DIR=/app/storage

# Admin token — used on /admin to grant full access to buyers
ADMIN_TOKEN=change-me-long-random-string

# Payments — DORMANT. Leave blank for now.
# Will be replaced by WHOP / JVZoo / WarriorPlus later.
