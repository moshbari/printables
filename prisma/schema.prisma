// Printables database schema
// Users, Generations, Subscriptions — keep it tight.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  name             String?
  emailVerified    DateTime?
  image            String?
  createdAt        DateTime       @default(now())
  stripeCustomerId String?        @unique
  tier             Tier           @default(FREE)
  subscriptionId   String?
  subEndsAt        DateTime?
  freeUsed         Boolean        @default(false)
  generations      Generation[]
  accounts         Account[]
  sessions         Session[]
}

enum Tier {
  FREE
  PRO
}

model Generation {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea        String
  template    String
  status      String   @default("pending") // pending | ready | failed
  title       String?
  description String?  @db.Text
  tags        String[] @default([])
  price       Float?
  pdfPath     String?
  zipPath     String?
  coverPath   String?
  createdAt   DateTime @default(now())
}

// NextAuth tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
